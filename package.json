{
  "name": "vortiqaa-technologies",
  "private": true,
  "version": "1.0.4",
  "repository": "https://github.com/rohithnnair/vortiqaa",
  "description": "Premium Management System for Vortiqaa Technologies",
  "author": "Vortiqaa Technologies",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5177 && electron .\"",
    "electron:build": "rimraf release && vite build && electron-builder"
  },
  "build": {
    "publish": [
      "github"
    ],
    "appId": "com.vortiqaa.management",
    "productName": "Vortiqaa Management",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.js",
      "package.json"
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.3.9",
    "firebase": "^11.0.0",
    "framer-motion": "^11.11.0",
    "html2pdf.js": "^0.10.2",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  }
}
