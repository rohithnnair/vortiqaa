{
  "name": "vortiqaa-technologies",
  "private": true,
  "version": "1.0.2",
  "repository": "https://github.com/rohithnnair/vortiqaa",
  "description": "Premium Management System for Vortiqaa Technologies",
  "author": "Vortiqaa Technologies",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "rimraf release && vite build && electron-builder"
  },
  "build": {
    "publish": [
      "github"
    ],
    "appId": "com.vortiqaa.management",
    "productName": "Vortiqaa Management",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.js",
      "package.json"
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.14.0",
    "framer-motion": "^11.18.2",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.453.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
